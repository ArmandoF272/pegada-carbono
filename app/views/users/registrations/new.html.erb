<% content_for :title, "Criar conta · Pegada de Carbono" %>

<div class="min-h-[80vh] flex items-center justify-center py-8">
  <div class="w-full">
    <div class="text-center mb-8">
      <div class="w-14 h-14 bg-leaf rounded-2xl mx-auto mb-4 flex items-center justify-center">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-ink">Criar conta</h1>
      <p class="text-sm text-ink-mute mt-1">Comece a monitorar sua pegada</p>
    </div>

    <div class="card">
      <%= render "users/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="space-y-3">
          <div>
            <%= f.label :name, "Nome", class: "text-sm text-ink-soft block mb-1" %>
            <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "input-field" %>
          </div>
          <div>
            <%= f.label :email, "E-mail", class: "text-sm text-ink-soft block mb-1" %>
            <%= f.email_field :email, autocomplete: "email", class: "input-field" %>
          </div>
          <div>
            <%= f.label :password, "Senha", class: "text-sm text-ink-soft block mb-1" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-ink-mute mb-1">Mínimo <%= @minimum_password_length %> caracteres</p>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: "input-field" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Confirmar senha", class: "text-sm text-ink-soft block mb-1" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input-field" %>
          </div>
          <%= f.submit "Criar conta", class: "btn-primary w-full mt-1 cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-4 text-center">
        <p class="text-sm text-ink-mute">Já tem conta?
          <%= link_to "Entrar", new_session_path(resource_name), class: "text-leaf font-medium" %>
        </p>
      </div>
    </div>
  </div>
</div>
