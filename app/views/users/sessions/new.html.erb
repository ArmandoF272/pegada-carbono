<% content_for :title, "Entrar · Pegada de Carbono" %>

<div class="min-h-[80vh] flex items-center justify-center py-8">
  <div class="w-full">
    <div class="text-center mb-8">
      <div class="w-14 h-14 bg-leaf rounded-2xl mx-auto mb-4 flex items-center justify-center">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-ink">Pegada de Carbono</h1>
      <p class="text-sm text-ink-mute mt-1">Monitore seu impacto ambiental</p>
    </div>

    <div class="card">
      <h2 class="text-base font-semibold text-ink mb-4">Entrar na sua conta</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-3">
          <div>
            <%= f.label :email, "E-mail", class: "text-sm text-ink-soft block mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-field" %>
          </div>
          <div>
            <%= f.label :password, "Senha", class: "text-sm text-ink-soft block mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "input-field" %>
          </div>
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me %>
              <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-ink-soft" %>
            </div>
          <% end %>
          <%= f.submit "Entrar", class: "btn-primary w-full mt-1 cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-4 text-center">
        <p class="text-sm text-ink-mute">Não tem conta?
          <%= link_to "Criar conta", new_registration_path(resource_name), class: "text-leaf font-medium" %>
        </p>
      </div>
    </div>
  </div>
</div>
