<% content_for :title, "Histórico · Pegada de Carbono" %>

<div class="mb-4">
  <h2 class="text-xl font-bold text-ink">Histórico</h2>
  <p class="text-xs text-ink-mute"><%= @calculations.size %> cálculos salvos · acompanhe sua evolução</p>
</div>

<%= form_with url: calculations_path, method: :get, class: "mb-4" do |f| %>
  <div class="relative">
    <svg class="absolute left-3 top-2.5 w-4 h-4 text-ink-mute" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    <%= f.text_field :q, value: @query, placeholder: "Buscar por mês ou ano...", class: "input-field pl-9 text-sm" %>
  </div>
<% end %>

<% if @calculations.any? %>
  <div class="space-y-2">
    <% @calculations.each do |calc| %>
      <%= link_to calculation_path(calc), class: "card flex items-center justify-between hover:border-leaf transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-leaf-tint rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-leaf" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064"/></svg>
          </div>
          <div>
            <p class="text-sm font-medium text-ink"><%= calc.formatted_month %></p>
            <p class="text-xs text-ink-mute">Salvo em <%= formatar_data(calc.updated_at) %></p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <div class="text-right">
            <p class="text-sm font-bold text-ink"><%= "%g" % calc.total_emission.to_f %></p>
            <% v = calc.variation_from_previous %>
            <% if v %>
              <p class="text-xs <%= v < 0 ? 'text-leaf' : 'text-ember' %>">
                <%= v > 0 ? "+" : "" %><%= "%g" % v %>
              </p>
            <% end %>
          </div>
          <svg class="w-4 h-4 text-ink-mute" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="card text-center py-10">
    <p class="text-ink-mute text-sm">Nenhum cálculo encontrado.</p>
    <%= link_to "Fazer novo cálculo", new_calculation_path, class: "btn-primary text-sm mt-3 inline-block" %>
  </div>
<% end %>

<div class="fixed bottom-20 right-4">
  <%= link_to new_calculation_path, class: "w-12 h-12 bg-leaf rounded-full flex items-center justify-center shadow-lg hover:bg-leaf-deep transition-colors" do %>
    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
  <% end %>
</div>
