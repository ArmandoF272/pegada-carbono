<% content_for :title, "Editar · #{@calculation.formatted_month}" %>

<div class="flex items-center gap-3 mb-5">
  <%= link_to calculation_path(@calculation), class: "text-ink-mute hover:text-ink" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  <% end %>
  <h2 class="text-base font-semibold text-ink">Editar · <%= @calculation.formatted_month %></h2>
</div>

<%= form_with url: calculation_path(@calculation), method: :patch, class: "space-y-5" do |f| %>
  <div class="card">
    <p class="text-xs text-leaf uppercase tracking-wide font-semibold mb-1">Transporte</p>
    <div class="space-y-3">
      <div>
        <label class="text-sm text-ink-soft block mb-1">Carro / moto (km/mês)</label>
        <div class="relative">
          <input type="number" name="transport[car_km]" value="<%= @calculation.transport_activity&.car_km.to_f %>" min="0" step="10" class="input-field pr-10 text-sm">
          <span class="absolute right-3 top-2.5 text-xs text-ink-mute">km</span>
        </div>
      </div>
      <div>
        <label class="text-sm text-ink-soft block mb-1">Ônibus / metrô (km/mês)</label>
        <div class="relative">
          <input type="number" name="transport[bus_km]" value="<%= @calculation.transport_activity&.bus_km.to_f %>" min="0" step="10" class="input-field pr-10 text-sm">
          <span class="absolute right-3 top-2.5 text-xs text-ink-mute">km</span>
        </div>
      </div>
      <div>
        <label class="text-sm text-ink-soft block mb-1">Voos no ano</label>
        <input type="number" name="transport[flights_per_year]" value="<%= @calculation.transport_activity&.flights_per_year.to_f %>" min="0" class="input-field text-sm">
      </div>
    </div>
  </div>

  <div class="card">
    <p class="text-xs text-leaf uppercase tracking-wide font-semibold mb-1">Energia</p>
    <div class="space-y-3">
      <div>
        <label class="text-sm text-ink-soft block mb-1">Consumo elétrico (kWh/mês)</label>
        <input type="number" name="energy[kwh_consumption]" value="<%= @calculation.energy_activity&.kwh_consumption.to_f %>" min="0" class="input-field text-sm">
      </div>
      <div>
        <label class="text-sm text-ink-soft block mb-1">Fonte de energia</label>
        <select name="energy[energy_source]" class="input-field text-sm">
          <% [["eletricidade", "Eletricidade (rede)"], ["solar", "Solar fotovoltaica"], ["gas_natural", "Gás natural"]].each do |val, label| %>
            <option value="<%= val %>" <%= 'selected' if @calculation.energy_activity&.energy_source == val %>><%= label %></option>
          <% end %>
        </select>
      </div>
    </div>
  </div>

  <div class="card">
    <p class="text-xs text-leaf uppercase tracking-wide font-semibold mb-1">Alimentação</p>
    <div class="space-y-3">
      <div>
        <label class="text-sm text-ink-soft block mb-1">Tipo de dieta</label>
        <select name="food[diet_type]" class="input-field text-sm">
          <% [["onivoro", "Onívoro"], ["vegetariano", "Vegetariano"], ["vegano", "Vegano"]].each do |val, label| %>
            <option value="<%= val %>" <%= 'selected' if @calculation.food_activity&.diet_type == val %>><%= label %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="text-sm text-ink-soft block mb-1">Carne vermelha (kg/mês)</label>
        <input type="number" name="food[meat_kg]" value="<%= @calculation.food_activity&.meat_kg.to_f %>" min="0" step="0.5" class="input-field text-sm">
      </div>
    </div>
  </div>

  <div class="card">
    <p class="text-xs text-leaf uppercase tracking-wide font-semibold mb-1">Compras</p>
    <div class="space-y-3">
      <div>
        <label class="text-sm text-ink-soft block mb-1">Gasto mensal (R$)</label>
        <div class="relative">
          <span class="absolute left-3 top-2.5 text-xs text-ink-mute">R$</span>
          <input type="number" name="shopping[monthly_spend]" value="<%= @calculation.shopping_activity&.monthly_spend.to_f %>" min="0" class="input-field pl-8 text-sm">
        </div>
      </div>
      <div>
        <label class="text-sm text-ink-soft block mb-1">Categoria principal</label>
        <select name="shopping[shopping_category]" class="input-field text-sm">
          <% [["eletronicos","Eletrônicos"],["roupas","Roupas"],["alimentos","Alimentos"],["servicos","Serviços"],["outros","Outros"]].each do |val, label| %>
            <option value="<%= val %>" <%= 'selected' if @calculation.shopping_activity&.shopping_category == val %>><%= label %></option>
          <% end %>
        </select>
      </div>
    </div>
  </div>

  <div class="flex gap-3 pb-2">
    <%= link_to "Cancelar", calculation_path(@calculation), class: "btn-secondary flex-1 text-center text-sm" %>
    <%= f.submit "Salvar alterações", class: "btn-primary flex-1 text-sm cursor-pointer" %>
  </div>
<% end %>
