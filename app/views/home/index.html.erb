<% content_for :title, "Início · Pegada de Carbono" %>

<% if @last_calculation %>
  <div class="bg-leaf rounded-2xl p-5 text-white mb-4">
    <p class="text-xs opacity-70 mb-1 uppercase tracking-wide">Último cálculo · <%= @last_calculation.formatted_month %></p>
    <p class="text-5xl font-bold mb-1"><%= "%g" % @last_calculation.total_emission.to_f %></p>
    <p class="text-sm opacity-80">tCO₂e / ano</p>

    <% variation = @last_calculation.variation_from_previous %>
    <% if variation %>
      <p class="mt-2 text-sm <%= variation < 0 ? 'text-green-300' : 'text-red-300' %>">
        <%= variation > 0 ? "+" : "" %><%= "%g" % variation %> vs. mês anterior
      </p>
    <% end %>

    <% pct = [(@last_calculation.total_emission.to_f / Calculation::PARIS_GOAL * 100).round, 100].min %>
    <div class="mt-3 bg-white/20 rounded-full h-1.5">
      <div class="bg-white rounded-full h-1.5" style="width: <%= pct %>%"></div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 mb-4">
    <div class="card text-center">
      <p class="text-xs text-ink-mute mb-1">Média Brasil</p>
      <p class="text-2xl font-bold text-ember"><%= Calculation::BRAZIL_AVERAGE %></p>
      <p class="text-xs text-ink-mute">tCO₂e</p>
      <% diff = (@last_calculation.total_emission.to_f - Calculation::BRAZIL_AVERAGE).round(2) %>
      <p class="text-xs mt-1 <%= diff < 0 ? 'text-leaf' : 'text-ember' %>">
        <%= diff < 0 ? "↓ #{diff.abs}t abaixo" : "↑ #{diff}t acima" %>
      </p>
    </div>
    <div class="card text-center">
      <p class="text-xs text-ink-mute mb-1">Meta Paris</p>
      <p class="text-2xl font-bold text-leaf"><%= Calculation::PARIS_GOAL %></p>
      <p class="text-xs text-ink-mute">tCO₂e</p>
      <% diff2 = (@last_calculation.total_emission.to_f - Calculation::PARIS_GOAL).round(2) %>
      <p class="text-xs mt-1 text-ink-mute">Faltam <%= diff2 > 0 ? "#{diff2}t" : "0t — meta atingida!" %></p>
    </div>
  </div>

<% else %>
  <div class="card text-center py-10 mb-4">
    <svg class="w-12 h-12 mx-auto text-leaf-soft mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <p class="text-ink-soft text-sm mb-4">Você ainda não tem cálculos salvos.<br>Comece agora!</p>
    <%= link_to "Calcular minha pegada", new_calculation_path, class: "btn-primary text-sm" %>
  </div>
<% end %>

<div class="grid grid-cols-2 gap-3 mb-5">
  <%= link_to new_calculation_path, class: "card flex items-center gap-3 hover:border-leaf transition-colors" do %>
    <div class="w-9 h-9 bg-leaf-tint rounded-lg flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-leaf" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    </div>
    <div>
      <p class="text-sm font-medium text-ink">Novo cálculo</p>
      <p class="text-xs text-ink-mute">Estimar mês atual</p>
    </div>
  <% end %>

  <%= link_to report_path, class: "card flex items-center gap-3 hover:border-leaf transition-colors" do %>
    <div class="w-9 h-9 bg-leaf-tint rounded-lg flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-leaf" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    </div>
    <div>
      <p class="text-sm font-medium text-ink">Relatório</p>
      <p class="text-xs text-ink-mute">Ver gráficos</p>
    </div>
  <% end %>
</div>

<% if @recent_calculations.any? %>
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-sm font-semibold text-ink">Cálculos recentes</h2>
    <%= link_to "Ver tudo →", calculations_path, class: "text-xs text-leaf" %>
  </div>
  <div class="space-y-2">
    <% @recent_calculations.each do |calc| %>
      <%= link_to calculation_path(calc), class: "card flex items-center justify-between hover:border-leaf transition-colors" do %>
        <div>
          <p class="text-sm font-medium text-ink"><%= calc.formatted_month %></p>
          <p class="text-xs text-ink-mute">Salvo em <%= formatar_data(calc.updated_at) %></p>
        </div>
        <div class="text-right">
          <p class="text-sm font-bold text-ink"><%= "%g" % calc.total_emission.to_f %></p>
          <% v = calc.variation_from_previous %>
          <% if v %>
            <p class="text-xs <%= v < 0 ? 'text-leaf' : 'text-ember' %>">
              <%= v > 0 ? "+" : "" %><%= "%g" % v %>
            </p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
